# OpenRouter — https://openrouter.ai/keys 에서 발급 (무료 모델만 사용)
OPENROUTER_API_KEY=

# Vercel Blob — Vercel Dashboard → Storage → Blob 연결 시 자동 설정
# 정지(suspended) 시: 새 Public Blob 생성 후 재연결, 또는 아래 S3/R2 사용
BLOB_READ_WRITE_TOKEN=

# S3 호환 스토리지 (Cloudflare R2 권장) — Blob 대체
# STORAGE_BACKEND=s3
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_REGION=auto

# 새 그림책 생성 시 기존 데이터 전체 삭제 (용량 초기화)
# Vercel 배포: 기본 true · 로컬: 기본 false · false 로 비활성화
# STORAGE_RESET_ON_GENERATE=true

# AI Hub — https://aihub.or.kr
AIHUB_API_KEY=
AIHUB_SHELL_PATH=

# App URL
NEXT_PUBLIC_APP_URL=http://127.0.0.1:50003
