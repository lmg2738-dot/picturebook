# OpenRouter — https://openrouter.ai/keys 에서 발급 (무료 모델만 사용)
OPENROUTER_API_KEY=

# ── Supabase Storage (권장, Blob 대체) ──
STORAGE_BACKEND=supabase
NEXT_PUBLIC_STORYSUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=storyseed

# (선택) 클라이언트용 — 현재 앱은 서버에서만 Storage 접근
# NEXT_PUBLIC_STORYSUPABASE_ANON_KEY=

# ── Vercel Blob (레거시) ──
# BLOB_READ_WRITE_TOKEN=

# ── S3 / Cloudflare R2 (대체) ──
# STORAGE_BACKEND=s3
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_REGION=auto

# 새 그림책 생성 시 기존 데이터 전체 삭제 (용량 초기화)
# Vercel 배포: 기본 true · STORAGE_RESET_ON_GENERATE=false 로 비활성화

# AI Hub — https://aihub.or.kr
AIHUB_API_KEY=
AIHUB_SHELL_PATH=

# App URL
NEXT_PUBLIC_APP_URL=http://127.0.0.1:50003
